{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "gcc -g -Wall ${workspaceFolder}/src/*.c -o ${workspaceFolder}/build/ascii-engine.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
